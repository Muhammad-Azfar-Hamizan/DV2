{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 640,
  "height": 340,
  "data": {
    "url": "data/aqi_annual.csv"
  },
  "resolve": {
    "scale": {
      "y": "shared"
    }
  },
  "layer": [
    {
      "description": "LAYER 1 \u2014 Shaded area under line",
      "mark": {
        "type": "area",
        "opacity": 0.15,
        "color": "#963068"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {
            "labelAngle": -30,
            "labelColor": "#555555",
            "titleColor": "#1a1a1a",
            "labelFontSize": 10,
            "titleFontSize": 11,
            "grid": false,
            "domainColor": "#cccccc"
          }
        },
        "y": {
          "field": "unhealthy_days",
          "type": "quantitative",
          "title": "Days with Air Pollutant Index above 100",
          "scale": {
            "domain": [
              0,
              175
            ]
          },
          "axis": {
            "labelColor": "#555555",
            "titleColor": "#1a1a1a",
            "gridColor": "#e0e0e0",
            "domainColor": "#cccccc",
            "labelFontSize": 10,
            "titleFontSize": 11
          }
        }
      }
    },
    {
      "description": "LAYER 2 \u2014 Main trend line with points",
      "mark": {
        "type": "line",
        "point": false,
        "strokeWidth": 2.2,
        "color": "#963068"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "unhealthy_days",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "unhealthy_days",
            "type": "quantitative",
            "title": "Unhealthy Air Days"
          },
          {
            "field": "worst_event",
            "type": "nominal",
            "title": "Haze Event"
          }
        ]
      }
    },
    {
      "comment": "LAYER 1b \u2014 Blue points for all years",
      "mark": {
        "type": "point",
        "filled": true,
        "size": 60,
        "color": "#963068"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "unhealthy_days",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "unhealthy_days",
            "type": "quantitative",
            "title": "Unhealthy Air Days"
          },
          {
            "field": "worst_event",
            "type": "nominal",
            "title": "Haze Event"
          }
        ]
      }
    },
    {
      "comment": "LAYER 1c \u2014 Orange highlighted points for annotated haze years",
      "transform": [
        {
          "filter": "datum.annotate == 'True'"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 80,
        "color": "#e07231",
        "stroke": "#b85000",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "unhealthy_days",
          "type": "quantitative"
        }
      }
    },
