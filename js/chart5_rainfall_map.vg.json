{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 570,
  "height": 240,
  "projection": {
    "type": "equalEarth",
    "center": [
      109,
      3.8
    ],
    "scale": 1900
  },
  "layer": [
    {
      "description": "LAYER 1 \u2014 Base fill for all states",
      "data": {
        "url": "js/malaysia.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#c8dce8",
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      }
    },
    {
      "description": "LAYER 2 \u2014 Choropleth: average annual rainfall by state (2014\u20132024)",
      "data": {
        "url": "js/malaysia.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {
              "url": "data/state_rainfall.csv"
            },
            "key": "state",
            "fields": [
              "avg_rainfall_mm"
            ]
          }
        },
        {
          "filter": "datum.avg_rainfall_mm != null"
        },
        {
          "calculate": "datum.avg_rainfall_mm < 2400 ? '< 2,400mm' : datum.avg_rainfall_mm < 2800 ? '2,400\u20132,800mm' : datum.avg_rainfall_mm < 3200 ? '2,800\u20133,200mm' : datum.avg_rainfall_mm < 3600 ? '3,200\u20133,600mm' : '\u2265 3,600mm'",
          "as": "rain_annual_bin"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      },
      "encoding": {
        "color": {
          "field": "rain_annual_bin",
          "type": "ordinal",
          "scale": {
            "domain": [
              "< 2,400mm",
              "2,400\u20132,800mm",
              "2,800\u20133,200mm",
              "3,200\u20133,600mm",
              "\u2265 3,600mm"
            ],
            "range": [
              "#c6dbef",
              "#9ecae1",
              "#6baed6",
              "#2171b5",
              "#08306b"
            ]
          },
          "legend": {
            "title": [
              "Average Annual",
              "Rainfall (mm)"
            ],
            "orient": "right",
            "labelColor": "#555555",
            "titleColor": "#1a1a1a",
            "titleFontSize": 10,
            "labelFontSize": 10,
            "titlePadding": 6,
            "offset": 8,
            "symbolType": "square",
            "symbolSize": 150
          }
        },
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "avg_rainfall_mm",
            "type": "quantitative",
            "title": "Average Annual Rainfall (mm)",
            "format": ",.0f"
          }
        ]
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#555555",
      "titleColor": "#1a1a1a",
      "gridColor": "#e0e0e0",
      "domainColor": "#cccccc"
    },
    "legend": {
      "labelColor": "#555555",
      "titleColor": "#1a1a1a"
    },
    "title": {
      "color": "#1a1a1a",
      "subtitleColor": "#555555"
    }
  }
}