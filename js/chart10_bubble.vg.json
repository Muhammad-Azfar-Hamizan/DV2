{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 640,
  "height": 400,
  "data": { "url": "data/climate_bubble.csv" },
  "transform": [
    {
      "filter": "datum.state !== 'Labuan' && datum.state !== 'Putrajaya' && datum.state !== 'Negeri Sembilan'"
    }
  ],
  "layer": [

    {
      "comment": "Danger zone shading — top-right",
      "data": { "values": [{ "x1": 27.8, "x2": 29.0, "y1": 12.5, "y2": 15.2 }] },
      "mark": { "type": "rect", "opacity": 0.05, "color": "#c0392b" },
      "encoding": {
        "x":  { "field": "x1", "type": "quantitative" },
        "x2": { "field": "x2", "type": "quantitative" },
        "y":  { "field": "y1", "type": "quantitative" },
        "y2": { "field": "y2", "type": "quantitative" }
      }
    },

    {
      "comment": "Danger zone label — inside the shaded area top-left corner",
      "data": { "values": [{ "x": 27.82, "y": 15.0, "label": "High risk zone" }] },
      "mark": {
        "type": "text", "fontSize": 8.5, "fontStyle": "italic",
        "color": "#c0392b", "opacity": 0.75, "align": "left"
      },
      "encoding": {
        "x":    { "field": "x", "type": "quantitative" },
        "y":    { "field": "y", "type": "quantitative" },
        "text": { "field": "label", "type": "nominal" }
      }
    },

    {
      "comment": "Bubble circles — single colour, reduced opacity so overlaps are see-through",
      "mark": {
        "type": "circle",
        "opacity": 0.60,
        "color": "#a07c00",
        "stroke": "#ffffff",
        "strokeWidth": 1.4
      },
      "encoding": {
        "x": {
          "field": "avg_temp", "type": "quantitative",
          "title": "Average Annual Temperature (°C)",
          "scale": { "domain": [25.5, 29.0], "zero": false },
          "axis": {
            "titleFontSize": 11, "titleColor": "#555555",
            "labelFontSize": 10, "labelColor": "#555555",
            "gridColor": "#eeeeee", "domainColor": "#cccccc",
            "tickCount": 8, "format": ".1f"
          }
        },
        "y": {
          "field": "median_uv", "type": "quantitative",
          "title": "Median Peak UV Index",
          "scale": { "domain": [9.5, 15.5], "zero": false },
          "axis": {
            "titleFontSize": 11, "titleColor": "#555555",
            "labelFontSize": 10, "labelColor": "#555555",
            "gridColor": "#eeeeee", "domainColor": "#cccccc",
            "tickCount": 7
          }
        },
        "size": {
          "field": "avg_rainfall", "type": "quantitative",
          "title": "Average Annual Rainfall (mm)",
          "scale": {
            "type": "linear",
            "domain": [1800, 4200],
            "range":  [60, 900]
          },
          "legend": {
            "title": "Average Annual Rainfall (mm)",
            "titleFontSize": 9, "labelFontSize": 8,
            "titleColor": "#1a1a1a", "labelColor": "#555555",
            "orient": "top-left",
            "values": [2000, 2500, 3000, 3600],
            "offset": 6, "symbolOpacity": 0.45
          }
        },
        "tooltip": [
          { "field": "state",        "type": "nominal",      "title": "State" },
          { "field": "median_uv",    "type": "quantitative", "title": "Median Peak UV Index" },
          { "field": "avg_temp",     "type": "quantitative", "title": "Average Annual Temperature (°C)", "format": ".1f" },
          { "field": "avg_rainfall", "type": "quantitative", "title": "Average Annual Rainfall (mm)",    "format": ",.0f" }
        ]
      }
    },

    {
      "comment": "Labels ABOVE — most states, standard small gap",
      "transform": [
        { "filter": "datum.state !== 'Melaka' && datum.state !== 'Terengganu' && datum.state !== 'Perak' && datum.state !== 'Johor' && datum.state !== 'Sarawak' && datum.state !== 'Selangor' && datum.state !== 'Sabah' && datum.state !== 'Kelantan' && datum.state !== 'Kuala Lumpur' && datum.state !== 'Pulau Pinang'" }
      ],
      "mark": {
        "type": "text",
        "fontSize": 8.5, "dy": -12,
        "align": "center", "color": "#333333", "fontWeight": "500"
      },
      "encoding": {
        "x":    { "field": "avg_temp",  "type": "quantitative" },
        "y":    { "field": "median_uv", "type": "quantitative" },
        "text": { "field": "state",     "type": "nominal" }
      }
    },

    {
      "comment": "Sarawak — largest bubble, needs bigger dy gap",
      "transform": [{ "filter": "datum.state === 'Sarawak'" }],
      "mark": { "type": "text", "fontSize": 8.5, "dy": -22, "align": "center", "color": "#333333", "fontWeight": "500" },
      "encoding": {
        "x": { "field": "avg_temp", "type": "quantitative" },
        "y": { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Sarawak" }
      }
    },

    {
      "comment": "Selangor — large bubble, needs bigger dy gap",
      "transform": [{ "filter": "datum.state === 'Selangor'" }],
      "mark": { "type": "text", "fontSize": 8.5, "dy": -20, "align": "center", "color": "#333333", "fontWeight": "500" },
      "encoding": {
        "x": { "field": "avg_temp", "type": "quantitative" },
        "y": { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Selangor" }
      }
    },

    {
      "comment": "Sabah — slightly higher label",
      "transform": [{ "filter": "datum.state === 'Sabah'" }],
      "mark": { "type": "text", "fontSize": 8.5, "dy": -16, "align": "center", "color": "#333333", "fontWeight": "500" },
      "encoding": {
        "x": { "field": "avg_temp", "type": "quantitative" },
        "y": { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Sabah" }
      }
    },

    {
      "comment": "Kelantan — slightly higher label",
      "transform": [{ "filter": "datum.state === 'Kelantan'" }],
      "mark": { "type": "text", "fontSize": 8.5, "dy": -16, "align": "center", "color": "#333333", "fontWeight": "500" },
      "encoding": {
        "x": { "field": "avg_temp", "type": "quantitative" },
        "y": { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Kelantan" }
      }
    },

    {
      "comment": "Kuala Lumpur — slightly higher label",
      "transform": [{ "filter": "datum.state === 'Kuala Lumpur'" }],
      "mark": { "type": "text", "fontSize": 8.5, "dy": -16, "align": "center", "color": "#333333", "fontWeight": "500" },
      "encoding": {
        "x": { "field": "avg_temp", "type": "quantitative" },
        "y": { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Kuala Lumpur" }
      }
    },

    {
      "comment": "Pulau Pinang — slightly higher label",
      "transform": [{ "filter": "datum.state === 'Pulau Pinang'" }],
      "mark": { "type": "text", "fontSize": 8.5, "dy": -16, "align": "center", "color": "#333333", "fontWeight": "500" },
      "encoding": {
        "x": { "field": "avg_temp", "type": "quantitative" },
        "y": { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Pulau Pinang" }
      }
    },

    {
      "comment": "Melaka — label BELOW bubble (smaller rainfall: 2,691 mm)",
      "transform": [{ "filter": "datum.state === 'Melaka'" }],
      "mark": {
        "type": "text",
        "fontSize": 8, "dy": 14,
        "align": "center", "color": "#555555",
        "fontStyle": "italic"
      },
      "encoding": {
        "x":    { "field": "avg_temp",  "type": "quantitative" },
        "y":    { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Melaka (less rainfall)" }
      }
    },

    {
      "comment": "Perak — label ABOVE with annotation (larger rainfall: 3,504 mm)",
      "transform": [{ "filter": "datum.state === 'Perak'" }],
      "mark": {
        "type": "text",
        "fontSize": 8, "dy": -14,
        "align": "center", "color": "#555555",
        "fontStyle": "italic"
      },
      "encoding": {
        "x":    { "field": "avg_temp",  "type": "quantitative" },
        "y":    { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Perak (more rainfall)" }
      }
    },

    {
      "comment": "Terengganu — label BELOW bubble, centred on its bubble",
      "transform": [{ "filter": "datum.state === 'Terengganu'" }],
      "mark": {
        "type": "text",
        "fontSize": 8.5, "dy": 14,
        "align": "center", "color": "#333333", "fontWeight": "500"
      },
      "encoding": {
        "x":    { "field": "avg_temp",  "type": "quantitative" },
        "y":    { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Terengganu" }
      }
    },

    {
      "comment": "Johor — centred above its own bubble, no dx shift",
      "transform": [{ "filter": "datum.state === 'Johor'" }],
      "mark": {
        "type": "text",
        "fontSize": 8.5, "dy": -12,
        "align": "center", "color": "#333333", "fontWeight": "500"
      },
      "encoding": {
        "x":    { "field": "avg_temp",  "type": "quantitative" },
        "y":    { "field": "median_uv", "type": "quantitative" },
        "text": { "value": "Johor" }
      }
    }

  ],

  "config": {
    "background": "transparent",
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#555555", "titleColor": "#555555",
      "gridColor": "#eeeeee",  "domainColor": "#cccccc"
    },
    "legend": { "labelColor": "#555555", "titleColor": "#1a1a1a" },
    "title":  { "color": "#1a1a1a",      "subtitleColor": "#555555" }
  }
}
